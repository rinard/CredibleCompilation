var n : int, i : int, j : int, t : int, r : int;
array A[1024] : int, B[1024] : int;
n := 3;
A[0] := 1; A[1] := 2; A[2] := 3;
A[3] := 4; A[4] := 5; A[5] := 6;
A[6] := 7; A[7] := 8; A[8] := 9;
i := 0;
while (i < n) {
  j := 0;
  while (j < n) {
    B[j * n + i] := A[i * n + j];
    j := j + 1
  };
  i := i + 1
};
r := B[0] * 100000000 + B[1] * 10000000 + B[2] * 1000000 +
     B[3] * 100000 + B[4] * 10000 + B[5] * 1000 +
     B[6] * 100 + B[7] * 10 + B[8]
