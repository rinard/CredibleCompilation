var n : int, i : int, j : int, idx : int, checksum : int;
array A[1024] : int, B[1024] : int, C[1024] : int;
n := 32;
i := 0;
while (i < n) {
  j := 0;
  while (j < n) {
    idx := i * n + j;
    A[idx] := i * 5 + j * 3 + 1;
    B[idx] := i * 2 + j * 7 + 4;
    j := j + 1
  };
  i := i + 1
};
i := 0;
while (i < n) {
  j := 0;
  while (j < n) {
    idx := i * n + j;
    C[idx] := A[idx] + B[idx];
    j := j + 1
  };
  i := i + 1
};
i := 0;
while (i < n) {
  j := 0;
  while (j < n) {
    idx := i * n + j;
    C[idx] := C[idx] - A[idx];
    j := j + 1
  };
  i := i + 1
};
checksum := 0;
i := 0;
while (i < n) {
  j := 0;
  while (j < n) {
    checksum := checksum + C[i * n + j];
    j := j + 1
  };
  i := i + 1
};
skip
