var n : int, i : int, j : int, t : int, r : int;
array A[1024];
n := 5;
A[0] := 5;
A[1] := 3;
A[2] := 1;
A[3] := 4;
A[4] := 2;
i := 0;
while (i < n - 1) {
  j := 0;
  while (j < n - 1 - i) {
    if (A[j] > A[j + 1]) {
      t := A[j];
      A[j] := A[j + 1];
      A[j + 1] := t
    } else { skip };
    j := j + 1
  };
  i := i + 1
};
r := A[0] * 10000 + A[1] * 1000 + A[2] * 100 + A[3] * 10 + A[4]
