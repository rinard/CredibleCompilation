var n : int, i : int, j : int, k : int, s : int, trace : int, checksum : int;
array A[1024] : int, B[1024] : int, C[1024] : int;
n := 16;
i := 0;
while (i < n) {
  j := 0;
  while (j < n) {
    A[i * n + j] := (i * 3 + j * 5 + 1) % 100;
    B[i * n + j] := (i * 7 + j * 2 + 3) % 100;
    j := j + 1
  };
  i := i + 1
};
i := 0;
while (i < n) {
  j := 0;
  while (j < n) {
    s := 0;
    k := 0;
    while (k < n) {
      s := s + A[i * n + k] * B[k * n + j];
      k := k + 1
    };
    C[i * n + j] := s;
    j := j + 1
  };
  i := i + 1
};
trace := 0;
checksum := 0;
i := 0;
while (i < n) {
  trace := trace + C[i * n + i];
  j := 0;
  while (j < n) {
    checksum := checksum + C[i * n + j];
    j := j + 1
  };
  i := i + 1
};
skip
