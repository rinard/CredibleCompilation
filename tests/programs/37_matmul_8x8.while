var n : int, i : int, j : int, k : int, s : int, trace : int;
array A[1024] : int, B[1024] : int, C[1024] : int;
n := 8;
i := 0;
while (i < n) {
  j := 0;
  while (j < n) {
    A[i * n + j] := i * n + j + 1;
    B[i * n + j] := (i + j) % 7 + 1;
    j := j + 1
  };
  i := i + 1
};
i := 0;
while (i < n) {
  j := 0;
  while (j < n) {
    s := 0;
    k := 0;
    while (k < n) {
      s := s + A[i * n + k] * B[k * n + j];
      k := k + 1
    };
    C[i * n + j] := s;
    j := j + 1
  };
  i := i + 1
};
trace := 0;
i := 0;
while (i < n) {
  trace := trace + C[i * n + i];
  i := i + 1
};
skip
