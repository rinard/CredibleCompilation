var n : int, i : int, j : int, checksum : int;
array A[1024] : int, B[1024] : int;
n := 16;
i := 0;
while (i < n) {
  j := 0;
  while (j < n) {
    A[i * n + j] := i * 100 + j;
    j := j + 1
  };
  i := i + 1
};
i := 0;
while (i < n) {
  j := 0;
  while (j < n) {
    B[j * n + i] := A[i * n + j];
    j := j + 1
  };
  i := i + 1
};
checksum := 0;
i := 0;
while (i < n) {
  j := 0;
  while (j < n) {
    checksum := checksum + B[i * n + j];
    j := j + 1
  };
  i := i + 1
};
skip
