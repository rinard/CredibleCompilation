var i : int, count : int;
array flags[16] : bool;
i := 0;
while (i < 16) {
  if (i / 2 * 2 == i) { flags[i] := true } else { flags[i] := false };
  i := i + 1
};
i := 0;
count := 0;
while (i < 16) {
  if (flags[i]) { count := count + 1 } else { count := count + 0 };
  i := i + 1
};
printString("count=");
printInt(count);
printString("\n")
